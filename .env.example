# Copiar a .env y completar. El archivo .env NUNCA se sube al repositorio.

# ── Aplicación ─────────────────────────────────────────────
APP_NAME="Disponibilidad de Flota"
APP_ENV=local            # local | production
APP_DEBUG=true           # false en producción
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC         # NO cambiar: la BD siempre trabaja en UTC (ver docs/plan §3.2)

# ── Base de datos (MySQL/MariaDB) ──────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=flota
DB_USERNAME=flota_user
DB_PASSWORD=

# ── Sesiones ───────────────────────────────────────────────
SESSION_NAME=flota_session
SESSION_LIFETIME=480     # minutos

# ── Correo (Fase 3 — notificaciones) ───────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_ENCRYPTION=tls      # tls | ssl | vacío si el servidor no lo requiere
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=notificaciones@empresa.com
